<ModelBrand
	DynamicModel="true"
	NightLightingShadowsAllowCap="true"
>
	<Subset IsDefault="true" Name="build_stage_0"> <!-- Empty stage -->
	</Subset>

	<Subset  Name="build_stage_1"> <!-- Unfoalding trailer -->
		<Mesh Name="state_00" />
		<Mesh Name="state_00_lod1" />
		<Mesh Name="state_00_lod2" />
		<Mesh Name="state_00_lod3" />
		<CdtMesh Name="cdt_state_00" />
		<Mesh Name="state_01" />
		<Mesh Name="state_01_lod1" />
		<Mesh Name="state_01_lod2" />
		<Mesh Name="state_01_lod3" />
		<Mesh Name="flare" />
		<CdtMesh Name="cdt_state_01" />
		<AnimTrack Name="stage_1_anim" />
		<AnimSubset Name="build_animation_0" />
		<AnimTrackSubset Name="anim_loop" />
		<OnSubsetActivateEvent>
			<Sound Name="actors/actor_vibro_sensor/actor_vibrator_seismo_loop" FadeInTime="1.0" FadeOutTime="1.0" RangeMin="25" RangeMax="120" IsLoop="true"/>
			<SFX Name="drilling_01_0" Dir="(0; 1; 0)" Pos="(-3.65; 0.35; 0.0)"/>
		</OnSubsetActivateEvent>
	</Subset>


	<AnimSubset Name="build_animation_0">
		<Mesh Name="animesh_01"/>
		<Mesh Name="animesh_02"/>
	</AnimSubset>

	<TrackEvents TrackName="stage_1_anim">
		<AnimEvent Key="0">
           		<Fade Time="0.2" />
				<Sound Name="actors/actor_construction/actor_construct_rus_drilling_rig_01_03" Range="50" Volume="0.7" />
       	</AnimEvent>
		<AnimEvent Key="40">
				<Sound Name="addons/bigcrane_ru/bigcrane_ru_open_stop" Range="50" Volume="1" />
       	</AnimEvent>
		<AnimEvent Key="60">	
				<Sound Name="addons/bigcrane_ru/bigcrane_ru_open_stop" Range="50" Volume="1" />
       	</AnimEvent>
		<AnimEvent Key="152">
           		<Fade Time="1.2" />
       	</AnimEvent>
	</TrackEvents>

	<PhysicsModel>
		<Body Collisions="Dynamic" ModelFrame="state_00">
			<Body Collisions="Dynamic" ModelFrame="state_01" />
		</Body>
	</PhysicsModel>
	<Landmark Mesh="landmarks/drilling_machine_ru17_objective_lmk" />
</ModelBrand>

