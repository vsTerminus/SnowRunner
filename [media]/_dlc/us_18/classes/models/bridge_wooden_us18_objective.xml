<_templates>
	<Constraint>
		<Bridge
			AxisLocal="(1; 0; 0)"
			MinLimit="-5"
			MaxLimit="0"
			Type="Hinge"
		>
			<AllMotor Damping="10000" Spring="400000" Type="Spring" />
		</Bridge>
	</Constraint>
	<Body>
		<Bridge
			AngularDamping="0.1"
			Mass="1000"
			NoSoftContacts="true"
			
		/>
	</Body>
</_templates>
<ModelBrand
	NightLightingShadowsAllowCap="true"
	ClipCameraBridge="False"
>
	<PhysicsModel>
		<Constraint
			_template="Bridge"
			ModelFrameChild="BoneBridgeL"
			ModelFrameParent="BoneColumn"
			PivotOffset="(0; 0; 0)"
		/>
		<Constraint
			_template="Bridge"
			ModelFrameChild="BoneBridgeR"
			ModelFrameParent="BoneColumn"
			PivotOffset="(0; 0; 0)"
		/>
		<Body _template="Bridge" Mass="0" ModelFrame="BoneColumn">
			<Body _template="Bridge" ModelFrame="BoneBridgeL">
				<Constraint _template="Bridge" />
			</Body>
			<Body _template="Bridge" ModelFrame="BoneBridgeR">
				<Constraint _template="Bridge" />
			</Body>
		</Body>
	</PhysicsModel>
	<Subset IsDefault="true" Name="stage_00">
	</Subset>
	<Subset Name="stage_01">
		<Mesh Name="mesh" />
		<Mesh Name="mesh_lod1" />
		<CdtMesh Name="cdt_BoneBridgeL" />
		<CdtMesh Name="cdt_BoneBridgeR" />
		<CdtMesh Name="cdt_BoneColumn" />
		<OnSubsetActivateEvent>
			<Sound Name="actors/actor_construction/actor_construct_bridge_logs_01" Range="50" Volume="1"/>
			<SFX Name="rail_blocker_smoke_01" Dir="(0; 1; 0)" Pos="(0.0; 0.0; 0.0)"/>
		</OnSubsetActivateEvent>

	</Subset>
	<Landmark Mesh="landmarks/bridge_wooden_us18_objective_lmk" />
</ModelBrand>
